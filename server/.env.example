# Path Backlog App – server environment
# Copy to .env and set values. Do not commit .env.

NODE_ENV=development
PORT=3000

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string

# Recovery "back door" – login even if DB is misconfigured. Keep secret.
RECOVERY_USER=recovery
RECOVERY_PASSWORD=change-me-secure-password

# Database path (default: SQLite file in server directory)
# DATABASE_PATH=./data/backlog.sqlite

# Optional: base URL for redirects (e.g. https://backlog.path2ai.tech)
# BASE_URL=https://backlog.path2ai.tech
